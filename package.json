{
  "name": "okuma-bc-app",
  "version": "1.0.0",
  "description": "Node.js/Express backend for Okuma BC — BigCommerce REST API integrations and webhook handling",
  "main": "dist/index.js",
  "private": true,
  "engines": {
    "node": ">=18.x",
    "npm": ">=9.x"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "node --env-file=.env.dev dist/index.js",
    "start:qa": "node --env-file=.env.qa dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:dev": "node scripts/run-env.js dev",
    "dev:qa": "node scripts/run-env.js qa",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "prepare": "node -e \"if(process.env.CI !== 'true' && require('fs').existsSync('../.git')) { require('child_process').execSync('cd .. && git config core.hooksPath .husky', {stdio:'inherit'}) }\""
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.0",
    "helmet": "^8.2.0",
    "morgan": "^1.10.0",
    "winston": "^3.19.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.3",
    "prettier": "^3.3.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  }
}
